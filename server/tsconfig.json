{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "allowJs": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node"],
    "rootDir": "./src",
    "outDir": "./dist",
  },
  "include": ["**/*.ts", "**/*.js"],
  "exclude": ["node_modules", "src/db/reset/generated", "tests", "**/*.config.ts"]
}